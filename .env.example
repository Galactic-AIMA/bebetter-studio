# ─── AWS S3 ───────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ─── Server ───────────────────────────────────────────────
PORT=3001
CLIENT_URL=http://localhost:5173

# ─── Paths ────────────────────────────────────────────────
# Ruta absoluta a tu banco de imágenes local
IMAGES_PATH=C:/Users/David/Documents/bebetter/Imagenes de referencia
# Carpeta donde se guardan los videos generados
OUTPUT_PATH=./output
# Ruta a la carpeta de fuentes personalizadas
FONTS_PATH=./data/fonts

# ─── n8n Webhooks ─────────────────────────────────────────
WEBHOOK_TEST_URL=https://n8n.galacticaima.com/webhook-test/videopublish
WEBHOOK_PROD_URL=https://n8n.galacticaima.com/webhook/videopublish

# ─── App ──────────────────────────────────────────────────
# URL pública de esta app (para generar links directos a videos locales)
# Ejemplo: http://localhost:3001 en dev, o https://tudominio.com en prod
PUBLIC_BASE_URL=http://localhost:3001

# ─── Pinterest ────────────────────────────────────────────
# Crear app en: https://developers.pinterest.com
# Redirect URI de la app: http://localhost:4322
# Scopes requeridos: boards:read, pins:read, offline_access
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_BOARD_ID=
PINTEREST_CREDENTIALS_PATH=./credentials/pinterest-token.json
